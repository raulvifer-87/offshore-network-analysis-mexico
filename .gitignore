**pycache**/
*.pyc
.ipynb_checkpoints/

# Raw/private/processed data should not be committed

data/raw/*
data/private/*
data/processed/*
outputs/*

# Keep folder structure

!data/raw/.gitkeep
!data/private/.gitkeep
!data/processed/.gitkeep
!outputs/matches/.gitkeep
!outputs/networks/.gitkeep

# Large or sensitive files

*.xlsx
*.zip
*.db
*.sqlite
*.graphml
*.gexf

.DS_Store
